# PostgreSQL connection string for app runtime. Use Railway-provided URL in cloud.
# Add ?sslmode=require for hosted Postgres providers (example shown).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sylvara?sslmode=require"

# Dedicated test database connection string.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:55432/sylvara_test"

# Company timezone used for schedule display/conversions.
COMPANY_TIMEZONE="America/New_York"

# Web app HTTP port in local development.
WEB_PORT="3000"

# API server HTTP port (Railway injects PORT at runtime).
API_PORT="4000"

# Host bind address for API server.
HOST_BIND="0.0.0.0"

# Public origin for the web app.
PUBLIC_WEB_ORIGIN="http://localhost:3000"

# Public origin for the API app.
API_PUBLIC_ORIGIN="http://localhost:4000"

# Clerk publishable key (from Clerk dashboard → API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace-me"

# Clerk secret key (from Clerk dashboard → API Keys).
CLERK_SECRET_KEY="sk_test_replace-me"

# Clerk webhook signing secret (from Clerk dashboard → Webhooks).
CLERK_WEBHOOK_SECRET="whsec_replace-me"

# Clerk sign-in URL (must match catch-all route).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"

# Comma-separated list of allowed browser origins for API CORS.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3100"

# Server-side API base URL used by web proxy/routes.
API_URL="http://localhost:4000"

# Runtime mode (development, test, production).
NODE_ENV="development"

# Railway/runtime-injected API port (optional locally; API_PORT is fallback).
PORT="4000"
