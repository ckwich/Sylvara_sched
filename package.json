{
  "name": "sylvara-sched",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "corepack pnpm --filter @sylvara/web dev",
    "lan": "node scripts/lan-dev.mjs",
    "lan:build": "corepack pnpm --filter @sylvara/shared build && corepack pnpm --filter @sylvara/api build && corepack pnpm --filter @sylvara/web build",
    "lan:start": "node scripts/lan-start.mjs",
    "lan:status": "node scripts/lan-status.mjs",
    "lan:stop": "node scripts/lan-stop.mjs",
    "lan:check": "node scripts/lan-check.mjs",
    "dev:all": "turbo run dev --parallel",
    "lint": "corepack pnpm -r lint",
    "format": "prettier --write .",
    "reset:schedule-day": "corepack pnpm --filter @sylvara/api reset:schedule-day --",
    "seed:lan-demo": "node scripts/seed-lan-demo.mjs",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:reset": "node scripts/test-db-reset.mjs",
    "test": "corepack pnpm test:smoke && corepack pnpm test:integration",
    "test:integration": "node scripts/test-integration.mjs",
    "test:api:smoke": "corepack pnpm --filter @sylvara/api test:smoke",
    "test:e2e:smoke": "corepack pnpm --filter @sylvara/e2e test:smoke",
    "test:smoke": "corepack pnpm test:api:smoke && corepack pnpm test:e2e:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
