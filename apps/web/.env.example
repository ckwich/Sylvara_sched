# PostgreSQL connection string (used by server-side code paths in monorepo development).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sylvara?sslmode=require"

# Auth.js JWT signing secret (must match API when forwarding JWTs).
AUTH_SECRET="replace-with-32-plus-char-random-secret"

# Auth.js canonical URL for this web app origin.
AUTH_URL="http://localhost:3000"

# Google OAuth client ID from Google Cloud Console.
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"

# Google OAuth client secret from Google Cloud Console.
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"

# Comma-separated list of browser origins allowed by API CORS.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3100"

# Server-side API base URL for web proxy route to call API service.
API_URL="http://localhost:4000"

# Node runtime mode.
NODE_ENV="development"
