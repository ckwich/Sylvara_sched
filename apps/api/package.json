{
  "name": "@sylvara/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "reset:schedule-day": "tsx scripts/reset-schedule-day.ts",
    "seed:lan-demo": "tsx scripts/seed-lan-demo.ts",
    "seed:admin": "tsx scripts/seed-admin-lists.ts",
    "seed:comparable": "tsx scripts/seed-comparable-history.ts",
    "import:master": "tsx scripts/import-master-sheet.ts",
    "import:link-pairs": "tsx scripts/link-paired-jobs.ts",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.4.1",
    "@sylvara/db": "workspace:*",
    "@sylvara/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.1",
    "jose": "^6.2.0",
    "node-cron": "^4.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
