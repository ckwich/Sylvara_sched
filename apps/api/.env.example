# PostgreSQL connection string for API service.
# Add ?sslmode=require for hosted Postgres providers (example shown).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sylvara?sslmode=require"

# API listener port (Railway injects PORT at runtime).
API_PORT="4000"

# Runtime port injected by cloud host (optional locally).
PORT="4000"

# API bind address.
HOST_BIND="0.0.0.0"

# Company timezone used for scheduling conversions.
COMPANY_TIMEZONE="America/New_York"

# Clerk secret key (from Clerk dashboard → API Keys).
CLERK_SECRET_KEY="sk_test_replace-me"

# Comma-separated list of allowed browser origins for API CORS.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3100"

# Node runtime mode.
NODE_ENV="development"
